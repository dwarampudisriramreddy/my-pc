            hb = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
            lbl = Gtk.Label(label=label); lbl.get_style_context().add_class('label-m'); lbl.set_halign(Gtk.Align.END)
            val = Gtk.Label(label='—'); val.get_style_context().add_class('label-v'); val.set_halign(Gtk.Align.START)
            self.rootfs_labels[key] = val
            hb.pack_start(lbl, False, False, 0); hb.pack_start(val, False, False, 0)
            s4.pack_start(hb, False, False, 0)
        vbox.pack_start(s4, False, False, 0)

        scr = Gtk.ScrolledWindow()
        scr.add(vbox)
        self.nb.append_page(scr, Gtk.Label(label='Settings'))

    # ─── Tab: About ──────────────────────────────────────────────────────────

