    # ─── Logic ───────────────────────────────────────────────────────────────

    def load_settings(self):
        pf = CONFIG_DIR / 'prefs.conf'
        if pf.exists():
            try:
                for line in pf.read_text().splitlines():
                    line = line.strip()
                    if '=' in line and not line.startswith('#'):
                        k, v = line.split('=', 1)
                        v = v.strip().strip('"\'')
                        k = k.lower()
                        if k == 'vnc_display' and 'vnc_display' in self.entries:
                            self.entries['vnc_display'].set_text(v)
                        elif k == 'vnc_geometry' and 'vnc_geometry' in self.entries:
                            self.entries['vnc_geometry'].set_text(v)
                        elif k == 'vnc_depth' and 'vnc_depth' in self.entries:
                            self.entries['vnc_depth'].set_text(v)
                        elif k == 'auto_start':
                            self.auto_switch.set_active(v.lower() == 'true')
            except:
                pass
        self._apply_vnc_settings()

    def _apply_vnc_settings(self):
        try:
            geo = self.entries['vnc_geometry'].get_text() if 'vnc_geometry' in self.entries else '1280x720'
            w, h = geo.split('x')
            self.vnc_width, self.vnc_height = int(w), int(h)
        except:
            self.vnc_width, self.vnc_height = 1280, 720
        try:
            self.vnc_port = int(self.entries['vnc_port'].get_text()) if 'vnc_port' in self.entries else 5901
        except:
            self.vnc_port = 5901
        self.vnc_host = self.entries['vnc_host'].get_text() if 'vnc_host' in self.entries else '127.0.0.1'

    def log(self, msg):
        buf = self.log_buf
        end = buf.get_end_iter()
        buf.insert(end, f'[{time.strftime("%H:%M:%S")}] {msg}\n')
        self.log_view.scroll_to_mark(buf.create_mark(None, buf.get_end_iter(), False), 0, True, 0, 1)

    def update_buttons(self):
        status, pid, port = desktop_status()
        if status == 'running':
            self.status_label.set_text('● Running')
            self.status_label.override_color(Gtk.StateFlags.NORMAL, Gdk.RGBA(0.18, 0.80, 0.44, 1))
            self.info_label.set_text(f'PID: {pid}  Port: {port}')
            self.start_btn.set_sensitive(False)
            self.stop_btn.set_sensitive(True)
        else:
            self.status_label.set_text('○ Stopped')
            self.status_label.override_color(Gtk.StateFlags.NORMAL, Gdk.RGBA(0.63, 0.63, 0.63, 1))
            self.info_label.set_text('')
            self.start_btn.set_sensitive(True)
            self.stop_btn.set_sensitive(False)

    def refresh_rootfs(self):
        st, sz, bs = rootfs_info()
        if 'rootfs_status' in self.rootfs_labels:
            self.rootfs_labels['rootfs_status'].set_text(st)
        if 'rootfs_location' in self.rootfs_labels:
            self.rootfs_labels['rootfs_location'].set_text(str(INSTALL_DIR))
        if 'rootfs_size' in self.rootfs_labels:
            self.rootfs_labels['rootfs_size'].set_text(sz or '—')
        if 'rootfs_bootstrapped' in self.rootfs_labels:
            self.rootfs_labels['rootfs_bootstrapped'].set_text('Yes' if bs else 'No')

    def refresh_all(self):
        self.update_buttons()
        self.refresh_rootfs()
        return True

    def connect_vnc_viewer(self):
        try:
            if HAVE_VNC_WIDGET:
                host = self.vnc_host
                self.vnc_display.close()
                self.vnc_display.open_host(host, self.vnc_port)
                self.log(f'VNC connected to {host}:{self.vnc_port}')
            else:
                self.vnc_display.connect_vnc(self.vnc_host, self.vnc_port)
                self.log(f'VNC (software) connected to {self.vnc_host}:{self.vnc_port}')
        except Exception as e:
            self.log(f'VNC connection failed: {e}')

    def disconnect_vnc_viewer(self):
        try:
            if HAVE_VNC_WIDGET:
                self.vnc_display.close()
            else:
                self.vnc_display.disconnect_vnc()
        except:
            pass

    # ─── Signal Handlers ─────────────────────────────────────────────────────

    def on_start(self, widget):
        self.log('Starting desktop session...')
        rc, out, err = vnc_start()
        if rc == 0 or 'ready' in out or 'running' in out:
            self.log('VNC server starting, connecting viewer...')
        else:
            self.log(f'Start output: {out}')

        # Wait for VNC and connect
        GLib.timeout_add(1000, self._wait_and_connect, 0)

    def _wait_and_connect(self, attempt):
        status, pid, port = desktop_status()
        if status == 'running' and port:
            self.connect_vnc_viewer()
            self.log('Desktop ready!')
            self.update_buttons()
            return False
        if attempt > 15:
            self.log('Timed out waiting for VNC server')
            self.log(f'Check: {LOG_FILE}')
            self.update_buttons()
            return False
        if attempt == 0:
            self.log('Waiting for VNC server to be ready...')
        GLib.timeout_add(1500, self._wait_and_connect, attempt + 1)
        return False

    def on_stop(self, widget):
        self.log('Stopping desktop session...')
        self.disconnect_vnc_viewer()
        rc, out, err = vnc_stop()
        self.log(f'Desktop stopped')
        self.update_buttons()
        self.refresh_all()

    def on_save(self, widget):
        self._apply_vnc_settings()
        CONFIG_DIR.mkdir(parents=True, exist_ok=True)
        pf = CONFIG_DIR / 'prefs.conf'
        with open(pf, 'w') as f:
            f.write('# Termux Linux Desktop Preferences\n')
            for key in ['vnc_display', 'vnc_geometry', 'vnc_depth']:
                f.write(f'{key.upper()}="{self.entries[key].get_text()}"\n')
            f.write(f'VNC_PORT="{self.entries["vnc_port"].get_text()}"\n')
            f.write(f'VNC_HOST="{self.entries["vnc_host"].get_text()}"\n')
            f.write(f'AUTO_START={"true" if self.auto_switch.get_active() else "false"}\n')
        self.log('Settings saved')
        d = Gtk.MessageDialog(transient_for=self.window, flags=0, message_type=Gtk.MessageType.INFO,
                              buttons=Gtk.ButtonsType.OK, text='Settings Saved')
        d.format_secondary_text(str(pf))
        d.run(); d.destroy()

    def on_setup(self, widget):
        d = Gtk.MessageDialog(transient_for=self.window, flags=0, message_type=Gtk.MessageType.QUESTION,
                              buttons=Gtk.ButtonsType.YES_NO, text='Run Setup?')
        d.format_secondary_text('Install proot, Ubuntu rootfs, XFCE, and VNC server.\nRequires internet. May take several minutes.')
        r = d.run(); d.destroy()
        if r == Gtk.ResponseType.YES:
            self.log('Running setup in terminal...')
            sp = Path(__file__).parent / 'setup.sh'
            subprocess.Popen(['bash', str(sp)])
            self.log('Setup started')

    def run(self):
        if self.setup_needed:
            d = Gtk.MessageDialog(transient_for=self.window, flags=0, message_type=Gtk.MessageType.QUESTION,
                                  buttons=Gtk.ButtonsType.YES_NO, text='First Run — Setup Required')
            d.format_secondary_text('Ubuntu rootfs is not installed.\nRun setup now to install proot + Ubuntu + XFCE + VNC?')
            r = d.run(); d.destroy()
            if r == Gtk.ResponseType.YES:
                sp = Path(__file__).parent / 'setup.sh'
                subprocess.Popen(['bash', str(sp)])
                self.log('Setup started in background')

        self.window.present()
        Gtk.main()


def main():
    app = TermuxLinuxApp()
    try:
        app.run()
    except KeyboardInterrupt:
        pass

if __name__ == '__main__':
    main()
