# ─── Shell Helpers ───────────────────────────────────────────────────────────

def sh(cmd, timeout=30):
    try:
        r = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)
        return r.returncode, r.stdout.strip(), r.stderr.strip()
    except Exception as e:
        return -1, '', str(e)

def get_vnc_port():
    try:
        if SESSION_FILE.exists():
            pid = int(SESSION_FILE.read_text().strip())
            if os.path.isdir(f'/proc/{pid}'):
                for port in [5901, 5902, 5900]:
                    try:
                        s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
                        s.settimeout(0.5)
                        r = s.connect_ex(('127.0.0.1', port))
                        s.close()
                        if r == 0:
                            return port
                    except:
                        pass
    except:
        pass
    return None

def desktop_status():
    if SESSION_FILE.exists():
        try:
            pid = int(SESSION_FILE.read_text().strip())
            if os.path.isdir(f'/proc/{pid}'):
                port = get_vnc_port()
                return 'running', pid, port
        except:
            pass
        SESSION_FILE.unlink(missing_ok=True)
    return 'stopped', None, None

def vnc_start():
    s = BIN_DIR / 'termux-linux-desktop'
    return sh(['bash', str(s), 'start']) if s.exists() else (-1, '', 'not found')

def vnc_stop():
    s = BIN_DIR / 'termux-linux-desktop'
    if s.exists():
        return sh(['bash', str(s), 'stop'])
    pid = get_vnc_port()
    if pid: os.kill(pid, signal.SIGTERM)
    return 0, '', ''

def rootfs_info():
    ok = INSTALL_DIR.exists() and (INSTALL_DIR / 'bin' / 'bash').exists()
    if ok:
        try:
            sz = subprocess.run(['du', '-sh', str(INSTALL_DIR)], capture_output=True, text=True).stdout.split()[0]
        except:
            sz = '?'
        bs = (INSTALL_DIR / '.bootstrapped').exists()
        return 'installed', sz, bs
    return 'not_installed', None, False

def open_terminal():
    session = BIN_DIR / 'termux-linux-session'
    if not session.exists():
        return
    term = os.environ.get('TERMINAL', '')
    if not term:
        for c in ['xfce4-terminal', 'gnome-terminal', 'konsole', 'xterm', 'lxterminal', 'foot']:
            if subprocess.run(['which', c], capture_output=True).returncode == 0:
                term = c; break
    if not term:
        term = 'xterm'
    subprocess.Popen([term, '-e', f'bash -c "exec {session}"'])

# ─── VNC Viewer Widget (GTK DrawingArea based) ──────────────────────────────
# Simple RFB pixel renderer as fallback when GtkVnc is not available

class RFBClient(threading.Thread):
    def __init__(self, host, port, width, height, on_update):
        super().__init__(daemon=True)
        self.host = host
        self.port = port
        self.width = width
        self.height = height
        self.on_update = on_update
        self.sock = None
        self.running = True
        self.pixels = bytearray(width * height * 4)

    def run(self):
        try:
            self.sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            self.sock.settimeout(10)
            self.sock.connect((self.host, self.port))
            self._handshake()
            while self.running:
                self._read_frame()
        except Exception as e:
            print(f"RFB error: {e}")
        finally:
            if self.sock: self.sock.close()

    def _handshake(self):
        s = self.sock
        buf = s.recv(12)
        assert buf[:4] == b'RFB '
        ver = buf[4:].decode()
        # Send 3.3
        s.send(b'RFB 003.003\n')
        # auth: none
        auth = s.recv(4)
        if auth[:1] == b'\x01':
            s.send(b'\x01')  # no auth
        elif auth[:1] == b'\x02':
            # VNC auth challenge
            chal = s.recv(16)
            s.send(b'\x00' * 16)  # dummy response
            result = s.recv(4)
        # client init: shared
        s.send(b'\x01')
        # server init
        data = s.recv(24)
        fmt = '!HBHHH' + 'H' * 16
        fw, fh = struct.unpack_from('!HH', data, 0)
        self.width, self.height = fw, fh
        # set pixel format: 32-bit BGRA
        s.send(b'\x00' + struct.pack('!BBBBHHHBBBB',
            32, 24, 0, 1,  # bpp, depth, bigendian, truecolor
            255, 255, 255,  # red, green, blue max
            16, 8, 0,       # red, green, blue shift
            0, 0, 0, 0, 0))  # padding
        s.send(b'\x02')  # set encodings
        s.send(struct.pack('!B', 1))  # padding + count
        s.send(struct.pack('!i', 0))  # raw encoding
        # framebuffer update request
        self._req_update()

    def _req_update(self):
        s = self.sock
        s.send(struct.pack('!BBHHHH', 3, 0, 0, 0, self.width, self.height))

    def _read_frame(self):
        s = self.sock
        while self.running:
            typ = s.recv(1)
            if not typ:
                break
            if typ == b'\x00':
                s.recv(1)  # padding
                num = struct.unpack('!H', s.recv(2))[0]
                for _ in range(num):
                    x, y, w, h, enc = struct.unpack('!HHHHi', s.recv(16))
                    if enc == 0:
                        data = s.recv(w * h * 4)
                        self._blit(data, x, y, w, h)
                        if self.on_update:
                            GLib.idle_add(self.on_update)
                self._req_update()
            elif typ == b'\x02':
                s.recv(3)  # bell
            else:
                break

    def _blit(self, data, x, y, w, h):
        for row in range(h):
            start = ((y + row) * self.width + x) * 4
            data_start = row * w * 4
            self.pixels[start:start + w * 4] = data[data_start:data_start + w * 4]

    def stop(self):
        self.running = False

class SimpleVncView(Gtk.DrawingArea):
    def __init__(self, width=1280, height=720):
        super().__init__()
        self.vnc_width = width
        self.vnc_height = height
        self.client = None
        self.pixels = bytearray(width * height * 4)
        self.set_size_request(width // 2, height // 2)
        self.connect('draw', self.on_draw)

        self.da = GdkPixbuf.Pixbuf.new_from_data(
            self.pixels, GdkPixbuf.Colorspace.RGB, True, 8, width, height, width * 4)
        # Note: above is simplified - we'll just use the draw signal

    def on_draw(self, widget, cr):
        w = self.get_allocated_width()
        h = self.get_allocated_height()

        cr.set_source_rgb(0.1, 0.1, 0.18)
        cr.rectangle(0, 0, w, h)
        cr.fill()

        if not self.client or not self.client.pixels:
            cr.set_source_rgb(0.4, 0.4, 0.5)
            cr.select_font_face('Sans', 0, 0)
            cr.set_font_size(18)
            te = cr.text_extents('Desktop Stopped')
            cr.move_to(w/2 - te.width/2, h/2)
            cr.show_text('Desktop Stopped')
            cr.set_font_size(13)
            te2 = cr.text_extents('Click "Start" above to launch XFCE')
            cr.move_to(w/2 - te2.width/2, h/2 + 30)
            cr.show_text('Click "Start" above to launch XFCE')
            return

        # Scale to fit
        sx = w / self.vnc_width
        sy = h / self.vnc_height
        scale = min(sx, sy)
        ox = (w - self.vnc_width * scale) / 2
        oy = (h - self.vnc_height * scale) / 2

        pixels = bytes(self.client.pixels) if self.client.pixels else self.pixels
        try:
            pb = GdkPixbuf.Pixbuf.new_from_bytes(
                GLib.Bytes.new(pixels),
                GdkPixbuf.Colorspace.RGB, True, 8,
                self.vnc_width, self.vnc_height,
                self.vnc_width * 4)
            scaled = pb.scale_simple(
                int(self.vnc_width * scale), int(self.vnc_height * scale),
                GdkPixbuf.InterpType.BILINEAR)
            Gdk.cairo_set_source_pixbuf(cr, scaled, ox, oy)
            cr.paint()
        except:
            pass

    def connect_vnc(self, host='127.0.0.1', port=5901):
        self.client = RFBClient(host, port, self.vnc_width, self.vnc_height, self.queue_draw)
        self.client.start()

    def disconnect_vnc(self):
        if self.client:
            self.client.stop()
            self.client = None
        self.queue_draw()

